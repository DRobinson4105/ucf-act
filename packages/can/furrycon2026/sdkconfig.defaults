# Project-wide TWAI defaults.
# Edit this file (or run `idf.py menuconfig`) to change settings.
# Do not hand-edit sdkconfig — it is generated.

CONFIG_APP_TWAI_TX_GPIO=4
CONFIG_APP_TWAI_RX_GPIO=5
CONFIG_APP_TWAI_BITRATE_1M=y
CONFIG_APP_TWAI_MODE_NO_ACK=y
CONFIG_APP_TWAI_TX_QUEUE_LEN=8
CONFIG_APP_TWAI_RX_QUEUE_LEN=8
CONFIG_APP_TWAI_DEFAULT_TIMEOUT_MS=100
CONFIG_APP_TWAI_LOG_TX=y
CONFIG_APP_TWAI_LOG_RX=y
CONFIG_APP_TWAI_LOG_ALERTS=y
